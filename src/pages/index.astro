---
// index.md: photo + aboutd
import { Image } from 'astro:assets';
import Buffer from '../layouts/Buffer.astro';
import { siteConfig } from '../../site.config';
import headshot from '../assets/tanjal_picture.jpeg';

const accents = ['red', 'green', 'yellow', 'blue', 'purple', 'cyan'];
---

<Buffer
  title={`${siteConfig.name} — ${siteConfig.tagline}`}
  description={siteConfig.tagline}
  currentPath="/"
>
  <div class="line">
    <div class="hero">
      <div class="hero-photo">
        <Image
          src={headshot}
          alt="tanjal"
          width={288}
          height={288}
          densities={[1, 2, 3]}
          quality={90}
          fit="cover"
          position="top"
          loading="eager"
          fetchpriority="high"
          class="hero-photo-img"
        />
      </div>
      <div class="hero-heading">
        <h1>{siteConfig.name}</h1>
        <p class="hero-tagline">{siteConfig.tagline}</p>
      </div>
    </div>
  </div>
  <div class="line">
    <p>I'm a software engineer at Amazon in Seattle, WA.</p>
  </div>
  <div class="line">
    <p>
      My current computing interests are in distributed systems, AI infra, and databases. I'm always
      looking for new papers to read, so if you have any recommendations please reach out.
    </p>
  </div>
  <div class="line">
    <p>
      I received my B.S. in Computer Science from the University of Washington – Seattle in 2026. I
      had the wonderful opportunity to conduct agentic engineering{' '}
      <a href="/research">research</a> for the{' '}
      <a href="https://social.cs.washington.edu/">Social Futures Lab</a> under the guidance of{' '}
      <a href="https://homes.cs.washington.edu/~axz/">Professor Amy X. Zhang</a>{' '}
      and{' '}
      <a href="https://kjfeng.me/#/">Kevin Feng</a>.
    </p>
  </div>

  <div class="line">
    <p>
      On the side, I enjoy playing/watching basketball, weightlifting/running,{' '}
      and debugging the endless compiler errors on the database I'm building in Rust. Feel free to connect
      with me through my LinkedIn and email below. Please enjoy using or learning <strong
        >Vim motions</strong
      > on this site!
    </p>
  </div>
  <div class="line">
    <ul class="accent-strip" aria-hidden="true">
      {accents.map((a) => <li style={`background: var(--${a})`} />)}
    </ul>
  </div>

  <style>
    .hero {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    @media (min-width: 480px) {
      .hero {
        flex-direction: row;
        align-items: center;
      }
    }

    .hero-photo {
      position: relative;
      flex-shrink: 0;
      width: 18rem;
      max-width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border: 1px solid var(--bg3);
      background: var(--bg1);
    }

    .hero-photo :global(.hero-photo-img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .hero-tagline {
      color: var(--green);
      margin-top: 0.25rem;
    }

    .accent-strip {
      display: flex;
      gap: 0.5rem;
      list-style: none;
    }

    .accent-strip li {
      width: 0.875rem;
      height: 0.875rem;
      border-radius: 9999px;
    }
  </style>
</Buffer>
