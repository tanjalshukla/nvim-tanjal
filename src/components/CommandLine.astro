---
// Command-line row (SPEC.md §6.5): always visible at the window's bottom
// edge — the `:` itself is the tap target (a <label for>, so clicking it
// focuses the input with zero JS). This replaces the v1 design (a separate
// trigger button that toggled a hidden row) — that button was the
// unspecced statusline icon the v2 revision calls out for removal; a
// permanently-visible row is simpler and matches §6.5's wording directly.
// The island (M3) wires the command grammar on top of this static shell.
---

<div class="cmdline-row" id="cmdline-row">
  <label for="cmdline-input" class="cmdline-prompt">:</label>
  <input
    type="text"
    id="cmdline-input"
    class="cmdline-input"
    autocomplete="off"
    autocapitalize="off"
    spellcheck="false"
    aria-label="Command line"
  />
  <span class="cmdline-message" id="cmdline-message" role="status" hidden></span>
</div>

<style>
  .cmdline-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: var(--bg0);
    border-top: 1px solid var(--bg3);
  }

  .cmdline-prompt {
    color: var(--yellow);
    font-weight: 700;
    cursor: text;
  }

  .cmdline-input {
    flex: 1;
    background: transparent;
    color: var(--fg);
    border: none;
    outline: none;
    font: inherit;
  }

  .cmdline-message {
    color: var(--red);
    font-size: 0.875rem;
  }
</style>
