---
// File-explorer sidebar (SPEC.md §6.1): primary nav, nvim-tree style, always
// expanded, living *inside* the bounded window (§6.0) — not viewport-fixed.
// Desktop renders a flex-child column; below desktop it's a native
// <details> drawer (keyboard/AT-clean without the island), opened by the
// statusline's "≡ files" button or the island's `Space e` binding.
import ExplorerTree from './ExplorerTree.astro';

interface Props {
  currentPath: string;
  mode?: 'desktop' | 'drawer';
}

const { currentPath, mode = 'desktop' } = Astro.props;
---

{
  mode === 'desktop' ? (
    <nav aria-label="explorer" class="explorer-desktop">
      <p class="explorer-root" aria-hidden="true">
        ~/tanjal
      </p>
      <ExplorerTree currentPath={currentPath} />
    </nav>
  ) : (
    <details class="explorer-drawer" id="explorer-drawer">
      <summary class="explorer-drawer-trigger">
        <svg
          class="explorer-drawer-icon"
          viewBox="0 0 16 16"
          width="1em"
          height="1em"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <line x1="2" y1="4" x2="14" y2="4" />
          <line x1="2" y1="8" x2="14" y2="8" />
          <line x1="2" y1="12" x2="14" y2="12" />
        </svg>
        files
      </summary>
      <nav aria-label="explorer" class="explorer-drawer-panel">
        <p class="explorer-root" aria-hidden="true">
          ~/tanjal
        </p>
        <ExplorerTree currentPath={currentPath} />
      </nav>
    </details>
  )
}

<style>
  .explorer-root {
    color: var(--cyan);
    margin-bottom: 0.5rem;
  }

  .explorer-desktop {
    display: none;
  }

  @media (min-width: 768px) {
    .explorer-desktop {
      display: block;
      flex-shrink: 0;
      width: 220px;
      overflow-y: auto;
      background: var(--bg-d);
      padding: 1.25rem 1rem;
      border-right: 1px solid var(--bg3);
    }
  }

  .explorer-drawer {
    position: relative;
  }

  @media (min-width: 768px) {
    .explorer-drawer {
      display: none;
    }
  }

  .explorer-drawer-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    cursor: pointer;
    color: var(--light-grey);
    list-style: none;
  }

  .explorer-drawer-trigger::-webkit-details-marker {
    display: none;
  }

  .explorer-drawer-trigger:hover {
    color: var(--fg);
  }

  .explorer-drawer[open] .explorer-drawer-panel {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: var(--bg-d);
    padding: 1.5rem;
    overflow-y: auto;
  }
</style>
