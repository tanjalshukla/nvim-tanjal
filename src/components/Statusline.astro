---
// Lualine-style statusline (SPEC.md §6.4): mode block · branch segment ·
// buffer path · spacer · contact links · theme toggle · scroll % + Ln:Col.
// Nothing else — the v1 build had a
// redundant cmdline-trigger button here that v2 explicitly calls out for
// removal (the command-line row is now always visible, see
// CommandLine.astro). Mode block and Ln:Col are static here; the island
// (M3) makes them live.
import { siteConfig, resolveBuffer } from '../../site.config';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const current = resolveBuffer(currentPath);
const bufferPath = `~/tanjal/${current.file}.md`;

type ContactIcon = 'github' | 'linkedin' | 'email';

const contacts: { icon: ContactIcon; href: string | null; title: string }[] = [
  { icon: 'github', href: siteConfig.links.github, title: 'GitHub' },
  { icon: 'linkedin', href: siteConfig.links.linkedin, title: 'LinkedIn' },
  { icon: 'email', href: siteConfig.email ? `mailto:${siteConfig.email}` : null, title: 'Email' },
];
---

<footer class="statusline">
  <span class="mode-block" id="mode-block" data-mode="NORMAL">[ NORMAL ]</span>
  <span class="branch-segment" aria-hidden="true"> main</span>
  <span class="path-segment">{bufferPath}</span>
  <span class="statusline-spacer"></span>
  <span class="contact-links">
    {
      contacts.map((c) => {
        const inner =
          c.icon === 'github' ? (
            <svg
              viewBox="0 0 24 24"
              width="1em"
              height="1em"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.237 1.838 1.237 1.07 1.834 2.809 1.304 3.495.997.107-.775.418-1.304.762-1.604-2.665-.305-5.466-1.334-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
          ) : c.icon === 'linkedin' ? (
            <svg
              viewBox="0 0 24 24"
              width="1em"
              height="1em"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          ) : (
            <svg
              viewBox="0 0 16 16"
              width="1em"
              height="1em"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="1" y="3" width="14" height="10" rx="1" />
              <polyline points="1.5,4 8,9.5 14.5,4" />
            </svg>
          );
        return c.href ? (
          <a
            href={c.href}
            target="_blank"
            rel="noopener"
            title={c.title}
            aria-label={c.title}
            class="contact-link"
          >
            {inner}
          </a>
        ) : (
          <span
            class="contact-link contact-link-pending"
            title={`${c.title} — TODO(owner)`}
            aria-label={`${c.title} — link pending`}
            aria-disabled="true"
          >
            {inner}
          </span>
        );
      })
    }
  </span>
  <button
    type="button"
    id="theme-toggle"
    class="theme-toggle"
    aria-label="Toggle color theme"
    title=":set bg="
  >
    <!-- JetBrains Mono has neither ☀ nor ☾ in its cmap — both are inline
         SVG per SPEC.md §2 rather than unicode chars that would silently
         fall back to a system font for just these two glyphs. -->
    <span id="theme-toggle-icon" aria-hidden="true">
      <svg
        class="theme-icon theme-icon-sun"
        viewBox="0 0 16 16"
        width="1em"
        height="1em"
        fill="currentColor"
      >
        <circle cx="8" cy="8" r="3.2"></circle>
        <g stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
          <line x1="8" y1="0.5" x2="8" y2="2.2"></line>
          <line x1="8" y1="13.8" x2="8" y2="15.5"></line>
          <line x1="0.5" y1="8" x2="2.2" y2="8"></line>
          <line x1="13.8" y1="8" x2="15.5" y2="8"></line>
          <line x1="2.6" y1="2.6" x2="3.8" y2="3.8"></line>
          <line x1="12.2" y1="12.2" x2="13.4" y2="13.4"></line>
          <line x1="2.6" y1="13.4" x2="3.8" y2="12.2"></line>
          <line x1="12.2" y1="3.8" x2="13.4" y2="2.6"></line>
        </g>
      </svg>
      <svg
        class="theme-icon theme-icon-moon"
        viewBox="0 0 16 16"
        width="1em"
        height="1em"
        fill="currentColor"
      >
        <path d="M14 9.5A6 6 0 0 1 6.5 2 6 6 0 1 0 14 9.5Z"></path>
      </svg>
    </span>
  </button>
  <span class="scroll-segment" id="scroll-segment" aria-hidden="true">Top</span>
  <span class="lncol-segment" id="lncol-segment" aria-hidden="true">0:0</span>
</footer>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    var icon = document.getElementById('theme-toggle-icon');
    function syncIcon() {
      var isLight = document.documentElement.getAttribute('data-theme') === 'light';
      if (icon) icon.classList.toggle('is-light', isLight);
    }
    syncIcon();
    if (btn) {
      btn.addEventListener('click', function () {
        var next =
          document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        try {
          localStorage.setItem('theme', next);
        } catch (e) {}
        syncIcon();
      });
    }
  })();
</script>

<style>
  .statusline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.375rem 0.75rem;
    background: var(--bg-d);
    border-top: 1px solid var(--bg3);
    font-size: 0.8125rem;
    /* Never a horizontal scroller — real lualine truncates. The path
       segment shrinks with ellipsis; decorative segments drop out below
       640px so the essentials (mode, contacts, theme) always fit. */
    overflow: hidden;
    white-space: nowrap;
  }

  .mode-block {
    background: var(--green);
    color: var(--bg0);
    font-weight: 700;
    padding: 0.125rem 0.5rem;
  }

  .mode-block[data-mode='VISUAL'] {
    background: var(--purple);
  }

  .mode-block[data-mode='COMMAND'] {
    background: var(--yellow);
  }

  .branch-segment,
  .scroll-segment,
  .lncol-segment {
    color: var(--grey);
  }

  .path-segment {
    color: var(--light-grey);
    flex-shrink: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 640px) {
    .branch-segment,
    .scroll-segment,
    .lncol-segment {
      display: none;
    }
  }

  .statusline-spacer {
    flex: 1;
  }

  .contact-links {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .contact-link {
    display: inline-flex;
    color: var(--cyan);
    font-size: 0.9375rem;
    line-height: 1;
  }

  .contact-link:hover {
    color: var(--fg);
  }

  .contact-link-pending {
    color: var(--grey);
    cursor: not-allowed;
  }

  .theme-toggle {
    color: var(--yellow);
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    padding: 0.125rem;
  }

  #theme-toggle-icon {
    display: inline-flex;
  }

  /* Default (no JS, or dark theme): moon — matches the pre-JS static state
     so there's no flash once the island loads. */
  .theme-icon-sun {
    display: none;
  }

  #theme-toggle-icon.is-light .theme-icon-sun {
    display: inline;
  }

  #theme-toggle-icon.is-light .theme-icon-moon {
    display: none;
  }
</style>
