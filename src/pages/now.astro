---
import Buffer from '../layouts/Buffer.astro';
import { siteConfig } from '../../site.config';

// TODO: [update this date whenever you edit this page's content]
const lastEdited = '2026-07-15';

// Versioning: before rewriting the page's content, snapshot what it said —
// copy the outgoing text into a new entry at the TOP of this array (newest
// first), stamped with the `lastEdited` date it was live under, then write
// the new content in the markup below and bump `lastEdited`. Old entries
// render under "## history" in muted styling; plain text only (no links) is
// fine for archives. Empty array = no history section at all.
type NowSnapshot = {
  date: string;
  sections: { heading: string; body: string }[];
};

const history: NowSnapshot[] = [];
---

<Buffer
  title={`now.md — ${siteConfig.name}`}
  description="What tanjal is learning and reading right now."
  currentPath="/now"
>
  <div class="line">
    <p class="last-edited">
      <span class="last-edited-label">last edited:</span>{' '}<span class="last-edited-date"
        >{lastEdited}</span
      >
    </p>
  </div>
  <div class="line">
    <h1>now.md</h1>
  </div>
  <div class="line">
    <h2 id="learning">learning</h2>
  </div>
  <div class="line">
    <p>
      I've been developing a Redis clone in Java as a side project, as well as learning Rust by
      building a database with it. Who knows where that will go :).
    </p>
  </div>
  <div class="line">
    <h2 id="reading">reading</h2>
  </div>
  <div class="line">
    <p>
      Currently about half of the way through <em>{siteConfig.reading}</em>. Full log, queue, and
      finished books live on <a href="/library">library.md</a>.
    </p>
  </div>
  {
    history.length > 0 && (
      <>
        <div class="line">
          <h2 id="history">history</h2>
        </div>
        <div class="line">
          <p class="history-hint">what this page used to say — newest first.</p>
        </div>
        {history.map((snap) => (
          <>
            <div class="line">
              <h3>{snap.date}</h3>
            </div>
            {snap.sections.map((s) => (
              <div class="line">
                <p class="history-body">
                  <span class="history-heading">{s.heading}:</span> {s.body}
                </p>
              </div>
            ))}
          </>
        ))}
      </>
    )
  }
</Buffer>

<style>
  .last-edited {
    font-size: 0.8125rem;
  }

  .last-edited-label {
    color: var(--purple);
  }

  .last-edited-date {
    color: var(--orange);
  }

  /* Archived snapshots read like comments — present but visually retired. */
  .history-hint {
    color: var(--grey);
    font-size: 0.8125rem;
  }

  .history-body {
    color: var(--light-grey);
  }

  .history-heading {
    color: var(--purple);
  }
</style>
