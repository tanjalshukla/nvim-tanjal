---
import Buffer from '../layouts/Buffer.astro';
import { siteConfig } from '../../site.config';

const queue = [
  'Effective Java',
  'A Philosophy of Software Design',
  'Database Internals',
  'Java Concurrency in Practice',
];
---

<Buffer
  title={`library.md — ${siteConfig.name}`}
  description="The reading log — currently reading, queue, and finished."
  currentPath="/library"
>
  <div class="line">
    <h1>library.md</h1>
  </div>
  <div class="line">
    <h2 id="reading-now">reading now</h2>
  </div>
  <ul class="library-list">
    <li class="line">{siteConfig.reading} <span class="progress-note">— ~1/3 through</span></li>
  </ul>
  <div class="line">
    <h2 id="queue">queue</h2>
  </div>
  <!-- TODO(owner): confirm order (SPEC.md §14 item — queue ordering). -->
  <ol class="library-list">
    {queue.map((title) => <li class="line">{title}</li>)}
  </ol>
  <div class="line">
    <h2 id="finished">finished</h2>
  </div>
  <div class="line">
    <p class="finished-note">
      TODO(owner): populate as books finish — title · year finished · optional note.
    </p>
  </div>
</Buffer>

<style>
  .library-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    list-style: none;
    padding-left: 0;
  }

  .progress-note {
    color: var(--orange);
    font-size: 0.8125rem;
  }

  .finished-note {
    color: var(--grey);
    font-size: 0.8125rem;
  }
</style>
