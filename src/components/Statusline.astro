---
// Lualine-style statusline (SPEC.md §6.4): mode block · explorer toggle ·
// branch segment · buffer path · spacer · contact links · theme toggle ·
// scroll %% + Ln:Col. Mode block and Ln:Col are static here; the island (M3)
// makes them live (selectionchange → VISUAL, focus → COMMAND, scroll math).
import Explorer from './Explorer.astro';
import CommandLine from './CommandLine.astro';
import { siteConfig, resolveBuffer } from '../../site.config';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const current = resolveBuffer(currentPath);
const bufferPath = `~/tanjal/${current.file}.md`;

const contacts: { label: string; href: string | null; title: string }[] = [
  { label: 'gh', href: siteConfig.links.github, title: 'GitHub' },
  { label: 'in', href: siteConfig.links.linkedin, title: 'LinkedIn' },
  { label: '@', href: siteConfig.email ? `mailto:${siteConfig.email}` : null, title: 'Email' },
];
---

<footer class="statusline">
  <span class="mode-block" id="mode-block" data-mode="NORMAL">[ NORMAL ]</span>
  <Explorer currentPath={currentPath} mode="drawer" />
  <span class="branch-segment" aria-hidden="true">main</span>
  <span class="path-segment">{bufferPath}</span>
  <span class="statusline-spacer"></span>
  <span class="contact-links">
    {
      contacts.map((c) =>
        c.href ? (
          <a href={c.href} target="_blank" rel="noopener" title={c.title} class="contact-link">
            {c.label}
          </a>
        ) : (
          <span
            class="contact-link contact-link-pending"
            title={`${c.title} — TODO(owner)`}
            aria-disabled="true"
          >
            {c.label}
          </span>
        )
      )
    }
  </span>
  <button
    type="button"
    id="theme-toggle"
    class="theme-toggle"
    aria-label="Toggle color theme"
    title=":set bg="
  >
    <span id="theme-toggle-icon" aria-hidden="true">☾</span>
  </button>
  <span class="scroll-segment" id="scroll-segment" aria-hidden="true">Top</span>
  <span class="lncol-segment" id="lncol-segment" aria-hidden="true">0:0</span>
  <CommandLine part="trigger" />
</footer>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    var icon = document.getElementById('theme-toggle-icon');
    function syncIcon() {
      var isDawn = document.documentElement.getAttribute('data-theme') === 'dawn';
      if (icon) icon.textContent = isDawn ? '☀' : '☾';
    }
    syncIcon();
    if (btn) {
      btn.addEventListener('click', function () {
        var next = document.documentElement.getAttribute('data-theme') === 'dawn' ? 'main' : 'dawn';
        document.documentElement.setAttribute('data-theme', next);
        try {
          localStorage.setItem('theme', next);
        } catch (e) {}
        syncIcon();
      });
    }
  })();
</script>

<style>
  .statusline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.375rem 0.75rem;
    background: var(--surface);
    border-top: 1px solid var(--hl-high);
    font-size: 0.8125rem;
    overflow-x: auto;
    white-space: nowrap;
  }

  .mode-block {
    background: var(--pine);
    color: var(--base);
    font-weight: 700;
    padding: 0.125rem 0.5rem;
  }

  .branch-segment,
  .scroll-segment,
  .lncol-segment {
    color: var(--muted);
  }

  .branch-segment::before {
    content: ' ';
  }

  .path-segment {
    color: var(--subtle);
  }

  .statusline-spacer {
    flex: 1;
  }

  .contact-links {
    display: flex;
    gap: 0.5rem;
  }

  .contact-link {
    color: var(--foam);
    text-decoration: none;
  }

  .contact-link:hover {
    color: var(--text);
  }

  .contact-link-pending {
    color: var(--muted);
    cursor: not-allowed;
  }

  .theme-toggle {
    color: var(--gold);
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    padding: 0.125rem;
  }
</style>
