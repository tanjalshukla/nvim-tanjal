---
// Flat file list (SPEC.md §3 — no nesting in v2). Connectors are ASCII
// (`|--`/`` `-- ``, the same convention `tree --charset ascii` uses) rather
// than Unicode box-drawing: JetBrains Mono doesn't include those glyphs, and
// falling back to a system font for them was exactly the v1 bug this avoids.
// Connectors are ::before content with a reserved fixed-width box so the
// trailing space before the filename can never get crowded out regardless
// of font metrics (the actual v1 bug, despite the content string already
// including a trailing space).
import { buffers } from '../../site.config';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<ul class="tree">
  {
    buffers.map((buf) => (
      <li>
        <a
          href={buf.path}
          class="tree-entry"
          class:list={{ 'tree-entry-current': currentPath === buf.path }}
          aria-current={currentPath === buf.path ? 'page' : undefined}
        >
          {buf.label}
        </a>
      </li>
    ))
  }
</ul>

<style>
  .tree {
    list-style: none;
  }

  .tree > li {
    position: relative;
    padding-left: 2.5rem;
    line-height: 1.9;
  }

  .tree > li::before {
    content: '|--';
    position: absolute;
    left: 0;
    width: 2.5rem;
    color: var(--grey);
    white-space: pre;
  }

  .tree > li:last-child::before {
    content: '`--';
  }

  .tree-entry {
    color: var(--light-grey);
    text-decoration: none;
  }

  .tree-entry:hover {
    color: var(--fg);
    background: var(--bg1);
  }

  .tree-entry-current {
    color: var(--fg);
    background: var(--bg1);
  }
</style>
