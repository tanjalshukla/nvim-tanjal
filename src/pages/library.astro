---
import Buffer from '../layouts/Buffer.astro';
import { siteConfig } from '../../site.config';

const queue = [
  'Effective Java (3rd Edition)',
  'Database Internals: A Deep Dive Into How Distributed Data Systems Work ',
  'Java Concurrency in Practice',
];

// Finished books go here — one line per book, newest first. `note` is
// optional. Example:
//   { title: 'The Pragmatic Programmer', year: 2025, note: 'reread every few years' },
const finished: { title: string; year: number; note?: string }[] = [
  {
    title: 'A Philosophy of Software Design',
    year: 2026,
    note: 'highly recommended, especially for engineers early in their careers',
  },
];
---

<Buffer
  title={`library.md — ${siteConfig.name}`}
  description="The reading log — currently reading, queue, and finished."
  currentPath="/library"
>
  <div class="line">
    <h1>library.md</h1>
  </div>
  <div class="line">
    <h2 id="reading-now">reading now</h2>
  </div>
  <ul class="library-list">
    <li class="line">{siteConfig.reading} <span class="progress-note">— ~1/2 through</span></li>
  </ul>
  <div class="line">
    <h2 id="queue">queue</h2>
  </div>
  <!-- TODO: [confirm/reorder the queue — edit the `queue` array in this file's frontmatter] -->
  <ol class="library-list">
    {queue.map((title) => <li class="line">{title}</li>)}
  </ol>
  <div class="line">
    <h2 id="finished">finished</h2>
  </div>
  {
    finished.length > 0 ? (
      <ul class="library-list">
        {finished.map((b) => (
          <li class="line">
            {b.title}{' '}
            <span class="finished-note">
              · {b.year}
              {b.note ? ` — ${b.note}` : ''}
            </span>
          </li>
        ))}
      </ul>
    ) : (
      <div class="line">
        <p class="finished-note">nothing logged yet</p>
      </div>
    )
  }
</Buffer>

<style>
  .library-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    list-style: none;
    padding-left: 0;
  }

  .progress-note {
    color: var(--orange);
    font-size: 0.8125rem;
  }

  .finished-note {
    color: var(--grey);
    font-size: 0.8125rem;
  }
</style>
