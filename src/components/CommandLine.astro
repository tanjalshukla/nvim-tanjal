---
// Command-line row (SPEC.md §6.4 second entry): a real `<input>` so mobile
// keyboards work. The trigger button lives in the statusline (a real tap
// path per SPEC.md §9) and the row itself renders below it, closed by
// default. Full behavior — opening on `:`, the command grammar, closing on
// Esc/submit — is wired by the island (M3). Progressive enhancement: every
// destination this can reach is also a plain link elsewhere in the chrome.
interface Props {
  part: 'trigger' | 'row';
}

const { part } = Astro.props;
---

{
  part === 'trigger' ? (
    <button
      type="button"
      id="cmdline-trigger"
      class="cmdline-trigger"
      aria-label="Open command line"
      aria-controls="cmdline-row"
      aria-expanded="false"
    >
      :
    </button>
  ) : (
    <div class="cmdline-row" id="cmdline-row" hidden>
      <label for="cmdline-input" class="cmdline-prompt" aria-hidden="true">
        :
      </label>
      <input
        type="text"
        id="cmdline-input"
        class="cmdline-input"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="Command line"
      />
    </div>
  )
}

<style>
  .cmdline-trigger {
    color: var(--gold);
    background: none;
    border: none;
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.125rem 0.375rem;
  }

  .cmdline-trigger:hover {
    color: var(--text);
  }

  .cmdline-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: var(--base);
    border-top: 1px solid var(--hl-high);
  }

  .cmdline-prompt {
    color: var(--gold);
    font-weight: 700;
  }

  .cmdline-input {
    flex: 1;
    background: transparent;
    color: var(--text);
    border: none;
    outline: none;
    font: inherit;
  }
</style>
