---
// File-explorer sidebar (SPEC.md §6.1): primary desktop nav, nvim-tree
// style, living *inside* the bounded window (§6.0) — not viewport-fixed.
// Desktop-only: below 768px the Bufferline top bar carries navigation
// instead (vim keys and a sidebar can't be assumed on mobile), so there is
// no drawer variant anymore.
import ExplorerTree from './ExplorerTree.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<nav aria-label="explorer" class="explorer-desktop">
  <p class="explorer-root" aria-hidden="true">~/tanjal</p>
  <ExplorerTree currentPath={currentPath} />
</nav>

<style>
  .explorer-root {
    color: var(--cyan);
    margin-bottom: 0.5rem;
  }

  .explorer-desktop {
    display: none;
  }

  @media (min-width: 768px) {
    .explorer-desktop {
      display: block;
      flex-shrink: 0;
      width: 220px;
      overflow-y: auto;
      background: var(--bg-d);
      padding: 1.25rem 1rem;
      border-right: 1px solid var(--bg3);
    }
  }

  /* Space e at desktop width (island sets/clears this attribute): collapse
     the sidebar, nvim-tree style. Higher specificity than the media rule
     above, so it wins regardless of order. */
  :global(html[data-explorer-hidden]) .explorer-desktop {
    display: none;
  }
</style>
