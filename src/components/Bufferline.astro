---
// Bufferline (SPEC.md §6.2): shows buffers opened *this session*. Static
// default is the current file only — the island (M3) appends visited buffers
// via sessionStorage and turns this into a real multi-tab bufferline.
import { resolveBuffer } from '../../site.config';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const current = resolveBuffer(currentPath);
---

<nav aria-label="buffers" class="bufferline">
  <a href={current.path} class="buffer-tab buffer-tab-active" aria-current="page">
    <!-- CSS-drawn dot, not a unicode ● — JetBrains Mono doesn't include that
         glyph (SPEC.md §2 covers this: plain unicode OR another approach;
         a drawn circle sidesteps font coverage entirely). -->
    <span class="buffer-marker" aria-hidden="true"></span>
    {current.label}
  </a>
</nav>

<style>
  .bufferline {
    display: flex;
    overflow-x: auto;
    background: var(--bg-d);
    border-bottom: 1px solid var(--bg3);
  }

  .buffer-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    color: var(--light-grey);
    text-decoration: none;
    white-space: nowrap;
  }

  .buffer-tab-active {
    color: var(--fg);
    background: var(--bg0);
  }

  .buffer-marker {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: var(--green);
    flex-shrink: 0;
  }
</style>
