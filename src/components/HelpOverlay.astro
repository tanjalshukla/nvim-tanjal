---
// Help overlay (SPEC.md §7 :help). Static keymap listing, hidden by
// default; the island (M3) toggles visibility and manages focus.
---

<div
  class="help-overlay"
  id="help-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="help-overlay-title"
  hidden
  tabindex="-1"
>
  <div class="help-panel">
    <h2 id="help-overlay-title">keymap</h2>
    <dl class="help-keys">
      <div><dt>j</dt><dd>scroll down</dd></div>
      <div><dt>k</dt><dd>scroll up</dd></div>
      <div><dt>gg</dt><dd>top</dd></div>
      <div><dt>G</dt><dd>bottom</dd></div>
      <div><dt>]b / L</dt><dd>next buffer</dd></div>
      <div><dt>[b / H</dt><dd>previous buffer</dd></div>
      <div><dt>Space e</dt><dd>toggle explorer</dd></div>
      <div><dt>:</dt><dd>command line</dd></div>
      <div><dt>/</dt><dd>fuzzy finder</dd></div>
      <div><dt>Space f f</dt><dd>fuzzy finder</dd></div>
      <div><dt>?</dt><dd>this help</dd></div>
      <div><dt>Esc</dt><dd>close overlay</dd></div>
    </dl>
    <h2>commands</h2>
    <dl class="help-keys">
      <div><dt>:e &lt;file&gt;</dt><dd>navigate (Tab-completes)</dd></div>
      <div><dt>:e!</dt><dd>hard reload</dd></div>
      <div><dt>:help</dt><dd>this overlay</dd></div>
      <div><dt>:set bg=light|dark</dt><dd>theme</dd></div>
      <div><dt>:q</dt><dd>—</dd></div>
      <div><dt>:q!</dt><dd>—</dd></div>
    </dl>
    <p class="help-close-hint">Esc to close · full reference: <a href="/motions">motions.md</a></p>
  </div>
</div>

<style>
  .help-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: color-mix(in srgb, var(--bg-d) 60%, transparent);
  }

  .help-panel {
    width: min(28rem, 90vw);
    max-height: 80vh;
    overflow-y: auto;
    background: var(--bg-d);
    border: 1px solid var(--bg3);
    padding: 1.5rem;
  }

  .help-panel h2 {
    color: var(--red);
    font-weight: 700;
    margin-top: 1rem;
  }

  .help-panel h2:first-child {
    margin-top: 0;
  }

  .help-keys {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }

  .help-keys > div {
    display: flex;
    gap: 0.75rem;
  }

  .help-keys dt {
    color: var(--orange);
    width: 9rem;
    flex-shrink: 0;
  }

  .help-keys dd {
    color: var(--fg);
  }

  .help-close-hint {
    margin-top: 1rem;
    color: var(--grey);
    font-size: 0.8125rem;
  }

  .help-close-hint a {
    color: var(--blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
