---
// index hero (SPEC.md §8.1). Photo/ASCII toggle wiring lands in M4; this
// renders the photo state only, with explicit dimensions so CLS stays 0
// once a real headshot replaces the placeholder.
import { siteConfig } from '../../site.config';

const accents: { name: string; var: string }[] = [
  { name: 'love', var: '--love' },
  { name: 'gold', var: '--gold' },
  { name: 'rose', var: '--rose' },
  { name: 'pine', var: '--pine' },
  { name: 'foam', var: '--foam' },
  { name: 'iris', var: '--iris' },
];
---

<div class="neofetch">
  <div class="neofetch-photo" id="neofetch-photo" style="width: 10rem; height: 10rem;">
    <!-- TODO(owner): replace with real headshot (SPEC.md §14 item 2) via astro:assets. -->
    <span class="neofetch-photo-note">photo<br />pending</span>
  </div>
  <div class="neofetch-info">
    <p class="neofetch-handle">{siteConfig.handle}</p>
    <p class="neofetch-rule" aria-hidden="true">─────────────────</p>
    <dl class="neofetch-dl">
      <div class="neofetch-row">
        <dt>role</dt>
        <dd>{siteConfig.role}</dd>
      </div>
      <div class="neofetch-row">
        <dt>edu</dt>
        <dd>{siteConfig.education}</dd>
      </div>
      <div class="neofetch-row">
        <dt>focus</dt>
        <dd>{siteConfig.focus}</dd>
      </div>
      <div class="neofetch-row">
        <dt>learning</dt>
        <dd>{siteConfig.learning}</dd>
      </div>
      <div class="neofetch-row">
        <dt>research</dt>
        <dd>
          {
            siteConfig.links.hedwig ? (
              <a href={siteConfig.links.hedwig} target="_blank" rel="noopener">
                {siteConfig.research} ↗
              </a>
            ) : (
              <span>
                {siteConfig.research}{' '}
                <span class="pending-note">(landing page link pending)</span>
              </span>
            )
          }
        </dd>
      </div>
      <div class="neofetch-row">
        <dt>reading</dt>
        <dd>
          {siteConfig.reading} — see <a href="/library">library.md</a>
        </dd>
      </div>
      <div class="neofetch-row">
        <dt>links</dt>
        <dd class="neofetch-links">
          {
            siteConfig.links.github ? (
              <a href={siteConfig.links.github} target="_blank" rel="noopener">
                github
              </a>
            ) : (
              <span class="pending-note">github (pending)</span>
            )
          }
          <span aria-hidden="true">·</span>
          {
            siteConfig.links.linkedin ? (
              <a href={siteConfig.links.linkedin} target="_blank" rel="noopener">
                linkedin
              </a>
            ) : (
              <span class="pending-note">linkedin (pending)</span>
            )
          }
          <span aria-hidden="true">·</span>
          <a href={siteConfig.links.resume} target="_blank" rel="noopener">resume ↗</a>
        </dd>
      </div>
    </dl>
    <ul class="neofetch-strip" aria-hidden="true">
      {
        accents.map((a) => (
          <li style={`background: var(${a.var})`} />
        ))
      }
    </ul>
  </div>
</div>

<style>
  .neofetch {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .neofetch {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .neofetch-photo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--hl-high);
    background: var(--surface);
  }

  .neofetch-photo-note {
    color: var(--muted);
    font-size: 0.75rem;
    text-align: center;
    line-height: 1.4;
  }

  .neofetch-handle {
    color: var(--text);
    font-weight: 700;
  }

  .neofetch-rule {
    color: var(--muted);
    margin-top: 0;
  }

  .neofetch-dl {
    margin-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .neofetch-row {
    display: flex;
    gap: 0.75rem;
  }

  .neofetch-row dt {
    color: var(--foam);
    width: 5.5rem;
    flex-shrink: 0;
  }

  .neofetch-row dd {
    color: var(--text);
  }

  .neofetch-row a {
    color: var(--iris);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .pending-note {
    color: var(--muted);
    font-size: 0.8125rem;
  }

  .neofetch-links {
    display: flex;
    gap: 0.5rem;
  }

  .neofetch-strip {
    display: flex;
    gap: 0.375rem;
    margin-top: 1rem;
    list-style: none;
  }

  .neofetch-strip li {
    width: 0.875rem;
    height: 0.875rem;
    border-radius: 9999px;
  }
</style>
