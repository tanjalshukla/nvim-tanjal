---
// index.md (SPEC.md §8.1): photo + about, the whole "who is this" answer on
// one screen — mitchellh.com register, not the retired neofetch hero.
import Buffer from '../layouts/Buffer.astro';
import { siteConfig } from '../../site.config';

const accents = ['red', 'green', 'yellow', 'blue', 'purple', 'cyan'];
---

<Buffer
  title={`${siteConfig.name} — ${siteConfig.tagline}`}
  description={siteConfig.tagline}
  currentPath="/"
>
  <div class="line">
    <div class="hero">
      <div class="hero-photo" style="width: 8rem; height: 8rem;">
        <!-- TODO(owner): replace with real headshot (SPEC.md §14 item 2) via astro:assets. -->
        <span class="hero-photo-note">photo<br />pending</span>
      </div>
      <div class="hero-heading">
        <h1>{siteConfig.name}</h1>
        <p class="hero-tagline">"{siteConfig.tagline}"</p>
      </div>
    </div>
  </div>
  <div class="line">
    <p>
      I'm a {siteConfig.role}. TODO(owner): one sentence on what the day job actually involves day
      to day — kept brief, no internal specifics (SPEC.md §13).
    </p>
  </div>
  <div class="line">
    <p>
      I'm into {siteConfig.focus}, and most of what I build lately sits somewhere in that space.
      TODO(owner): a real sentence on what you're building toward — a direction, not just a list of
      interests (SPEC.md §14 item 6, owner voice pass).
    </p>
  </div>
  <div class="line">
    <p>
      The path here ran through the University of Washington and into <a href="/research"
        >research</a
      > on AI–human coding collaboration before landing at Amazon.
    </p>
  </div>
  <div class="line">
    <p class="pending-note">
      TODO(owner): optional line of personal texture — your call on what's public (SPEC.md §14 item
      7). Omitted for now.
    </p>
  </div>
  <div class="line">
    <ul class="accent-strip" aria-hidden="true">
      {accents.map((a) => <li style={`background: var(--${a})`} />)}
    </ul>
  </div>
</Buffer>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .hero {
      flex-direction: row;
      align-items: center;
    }
  }

  .hero-photo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--bg3);
    background: var(--bg1);
  }

  .hero-photo-note {
    color: var(--grey);
    font-size: 0.75rem;
    text-align: center;
    line-height: 1.4;
  }

  .hero-tagline {
    color: var(--green);
    margin-top: 0.25rem;
  }

  .pending-note {
    color: var(--grey);
    font-size: 0.8125rem;
  }

  .accent-strip {
    display: flex;
    gap: 0.5rem;
    list-style: none;
  }

  .accent-strip li {
    width: 0.875rem;
    height: 0.875rem;
    border-radius: 9999px;
  }
</style>
